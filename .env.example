# ── Supabase ──────────────────────────────────────────────────────────────────
# Find all three values in: Supabase Dashboard → Settings → API / Database

# Direct PostgreSQL connection URL (port 5432 — for always-on Node.js server)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Set to "disable" only for a plain, non-TLS Postgres (local dev / CI service
# container). Leave unset for Supabase (TLS is used automatically).
# DATABASE_SSL=disable

# Supabase project URL (Settings → API → Project URL)
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co

# Service Role Key — server-side only, bypasses RLS. NEVER expose to clients.
# (Settings → API → Project API keys → service_role)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── WhatsApp — Meta Cloud API ─────────────────────────────────────────────────
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_access_token
WHATSAPP_VERIFY_TOKEN=your_webhook_verify_token

# App Secret — from Meta App Dashboard → App Settings → Basic → App Secret
# Used to verify the X-Hub-Signature-256 on every inbound webhook POST.
# REQUIRED in production; if unset, signature verification is skipped (dev only).
WHATSAPP_APP_SECRET=your_app_secret_here

# Meta Graph API version (default: v19.0)
WHATSAPP_API_VERSION=v19.0

# Proactive notifications (reminders, alerts, summaries) must use approved
# message templates when sent outside the 24h window. Set to "true" once the
# templates below are registered & approved in Meta WhatsApp Manager.
# Until then, proactive messages fall back to free-form text (dev / in-window only).
WHATSAPP_TEMPLATES_ENABLED=false
WHATSAPP_TEMPLATE_LANG=he
# Optional per-template name overrides (defaults shown in src/whatsapp/templates.ts):
#   WHATSAPP_TEMPLATE_DUE_REMINDER=...   WHATSAPP_TEMPLATE_DAILY_SUMMARY=...   etc.

# ── Scheduled digests (V1) ────────────────────────────────────────────────────
# Per-user morning/evening digests run every 5 min and are ON by default for
# every active user with a phone (overridable per-user via the WhatsApp menu).
# The legacy fixed 17:00 broadcast (dailySummary) is REPLACED by the evening
# digest and stays OFF unless you explicitly opt back in here.
LEGACY_DAILY_SUMMARY_ENABLED=false

# ── Internal security ─────────────────────────────────────────────────────────
# Shared secret between the webhook handler and the internal task routes.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# REQUIRED in production to prevent direct access to /tasks/* from the public internet.
INTERNAL_API_SECRET=your_random_secret_here

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Scheduler ────────────────────────────────────────────────────────────────
PENDING_ACTION_TTL_HOURS=24
DEADLINE_ALERT_HOURS=24

# ── AI layer (Phase 5) ────────────────────────────────────────────────────────
# Provider for intent parsing. Leave unset to disable AI (the bot replies that
# the AI is not configured). Switch providers with a single env change.
#   AI_PROVIDER=openai     → set OPENAI_API_KEY,    default model gpt-4o-mini
#   AI_PROVIDER=anthropic  → set ANTHROPIC_API_KEY, default model claude-haiku-4-5
AI_PROVIDER=openai
AI_MODEL=gpt-5.4-mini
OPENAI_API_KEY=

# Confidence thresholds: >=HIGH acts; [LOW,HIGH) asks to confirm; <LOW asks to rephrase
AI_CONFIDENCE_HIGH=0.85
AI_CONFIDENCE_LOW=0.60

# How long a partial clarification conversation is remembered
CONVERSATION_CONTEXT_TTL_MINUTES=10
