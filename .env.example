# =============================================================================
# WhatsApp Field-Inspection Bot — V2 environment configuration
# =============================================================================
# Copy this file to `.env` and fill in the values marked REQUIRED.
# Values marked OPTIONAL have safe defaults; leave them blank in dev.
# The bot preflight checks (src/config/preflight.ts) will fail fast on missing
# REQUIRED vars in production (NODE_ENV=production).


# ─────────────────────────────────────────────────────────────────────────────
# 1. Database (Supabase) — REQUIRED
# ─────────────────────────────────────────────────────────────────────────────
# Supabase Dashboard → Settings → Database → Connection string (port 5432).
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Set to "disable" ONLY for a plain non-TLS Postgres (local dev / CI). Leave
# unset for Supabase — TLS is used automatically.
# DATABASE_SSL=disable

# Supabase project URL (Settings → API → Project URL). REQUIRED.
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co

# Service Role Key — server-side only, bypasses RLS. REQUIRED. NEVER expose to clients.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here


# ─────────────────────────────────────────────────────────────────────────────
# 2. WhatsApp — Meta Cloud API (REQUIRED in production)
# ─────────────────────────────────────────────────────────────────────────────
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_access_token
WHATSAPP_VERIFY_TOKEN=your_webhook_verify_token

# App Secret (Meta App Dashboard → Basic → App Secret). Verifies inbound webhook
# signatures. REQUIRED in production; unset skips signature verification (dev only).
WHATSAPP_APP_SECRET=your_app_secret_here

# Meta Graph API version (default v19.0).
WHATSAPP_API_VERSION=v19.0


# ─────────────────────────────────────────────────────────────────────────────
# 3. V2 field-inspection routing — NO CONFIG NEEDED
# ─────────────────────────────────────────────────────────────────────────────
# Yoram + Sasha are identified by User.name at runtime (see specialUsers.ts):
#   User.name = 'יורם' → SPEC §13 exceptions digest (morning + evening)
#   User.name = 'סשה'  → SPEC §12 leads morning digest at 09:30
#                        + 1-hour escalation alerts for unassigned leads
# Everyone else (regardless of role) receives the SPEC §7 inspector morning
# digest + employee end-of-day summary. No env vars, no drift — the DB is the
# source of truth. If either name is missing from the User table, that digest
# is silently disabled.


# ─────────────────────────────────────────────────────────────────────────────
# 4. AI provider — REQUIRED for intent parsing + lead suggestions
# ─────────────────────────────────────────────────────────────────────────────
# Provider for intent parsing + AI lead-worker suggestion (D3-T5).
#   AI_PROVIDER=openai     → set OPENAI_API_KEY,    default model gpt-4o-mini
#   AI_PROVIDER=anthropic  → set ANTHROPIC_API_KEY, default model claude-haiku-4-5
# Leave unset to disable AI (bot replies "AI not configured"; leads get "לא נמצאה התאמה").
AI_PROVIDER=openai
AI_MODEL=gpt-4o-mini
OPENAI_API_KEY=

# Voice transcription (Whisper) uses OPENAI_API_KEY above. Voice inbound (D5-T2)
# no-ops silently when the key is unset.

# Confidence thresholds. >=HIGH acts; [LOW,HIGH) asks to confirm; <LOW asks to rephrase.
AI_CONFIDENCE_HIGH=0.85
AI_CONFIDENCE_LOW=0.60

# How long a partial clarification conversation is remembered (minutes).
CONVERSATION_CONTEXT_TTL_MINUTES=10


# ─────────────────────────────────────────────────────────────────────────────
# 5. Internal security — REQUIRED in production
# ─────────────────────────────────────────────────────────────────────────────
# Shared secret between the webhook handler and the internal task routes.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Prevents direct access to /tasks/* from the public internet.
INTERNAL_API_SECRET=your_random_secret_here


# ─────────────────────────────────────────────────────────────────────────────
# 6. Server (defaults are fine in dev)
# ─────────────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development


# ─────────────────────────────────────────────────────────────────────────────
# 7. Meta approved templates — REQUIRED before going live (D5-T5)
# ─────────────────────────────────────────────────────────────────────────────
# Proactive messages (digests, alerts, reminders) sent OUTSIDE the 24-hour
# customer-service window need Meta-approved templates. Until the templates
# below are registered & approved in Meta WhatsApp Manager, keep this FALSE —
# messages fall back to free-form text (works only in-window / dev).
#
# Templates to register (canonical names in src/whatsapp/templateNames.ts):
#   employee_morning_digest, manager_morning_digest,
#   employee_end_of_day_report, manager_end_of_day_report,
#   due_reminder, deadline_exceeded, deadline_approaching,
#   task_completed, request_expired, request_expired_manager
#
# The V2 field-inspection messages (assignment card, equipment reminder, Yoram
# exceptions, Sasha leads morning, lead-assignment worker alert, 1h escalation)
# are currently sent as free-form text — they typically hit in-window, so this
# is acceptable for MVP. Register templates for them when going fully live.
WHATSAPP_TEMPLATES_ENABLED=false
WHATSAPP_TEMPLATE_LANG=he
# Optional per-template name overrides:
#   WHATSAPP_TEMPLATE_DUE_REMINDER=my_custom_name   (etc.)
#
# Enhanced due-date reminder: after the new template `due_reminder_v2` is
# APPROVED at Meta, point the due-reminder key at it to render the full detail
# body + "פרטים נוספים" button out-of-window:
#   WHATSAPP_TEMPLATE_DUE_REMINDER=due_reminder_v2
# Keep it unset (or =due_reminder) while v2 is PENDING so out-of-window sends
# safely fall back to the old approved 2-var template.

# Optional: URL template for the CRM task view. When set, the due-date reminder
# body and the "פרטים נוספים" extended message include a link to the task in the
# CRM. Must include the literal placeholder `{taskId}` — the code substitutes it
# at send time. When unset, both messages render "—" in the CRM section (the
# template variable is filled with "—" so Meta accepts the send).
# Example: https://crm.galit.co.il/tasks/{taskId}
CRM_TASK_URL_TEMPLATE=


# ─────────────────────────────────────────────────────────────────────────────
# 8. Legacy feature gates — OPTIONAL (default OFF)
# ─────────────────────────────────────────────────────────────────────────────
# All of these are OFF by default — the V2 flows are the authoritative behavior.
# Set to "true" ONLY if you explicitly want the legacy path back.

# The old 17:00 fixed daily-summary broadcast (superseded by the per-user
# evening digest). Legacy.
LEGACY_DAILY_SUMMARY_ENABLED=false

# Product decision (Jul 2026): the bot does NOT auto-send a WhatsApp
# assignment card just because a TaskField was created / re-assigned. The
# code and DB schema (TaskField.workerNotifiedAt) are retained for a
# future explicit manual command ("שלח כרטיס בדיקה לעובד"). Legacy.
ASSIGNMENT_CARD_NOTIFIER_ENABLED=false

# X-T7 — completionNotifier: bot no longer writes Task.status; this job is
# retired. Keep OFF unless you're intentionally re-enabling the old detector.
COMPLETION_NOTIFIER_ENABLED=false

# Customer-facing WhatsApp notifications on TaskField state changes. Currently
# only WORKER_EN_ROUTE (sent when a worker flips fieldStatus to EN_ROUTE).
# Requires the `customer_worker_en_route` UTILITY template to be APPROVED at
# Meta. When OFF, sendWorkerEnRouteNotification is a no-op.
CUSTOMER_NOTIFICATIONS_ENABLED=false


# ─────────────────────────────────────────────────────────────────────────────
# 9. Scheduler tuning — OPTIONAL
# ─────────────────────────────────────────────────────────────────────────────
PENDING_ACTION_TTL_HOURS=24
DEADLINE_ALERT_HOURS=24

# Active-task context after "יצאתי": how long (minutes) the stored activeTaskFieldId
# stays the source of truth for follow-up "הגעתי"/"סיימתי" before the bot stops
# assuming and asks / falls back to a status search. Default 240 (4h).
ACTIVE_INSPECTION_DEFAULT_WINDOW_MINUTES=240


# ─────────────────────────────────────────────────────────────────────────────
# 10. OwnTracks GPS POC — OPTIONAL (see docs/POC_OWNTRACKS.md)
# ─────────────────────────────────────────────────────────────────────────────
# Per-worker HTTP Basic-auth allowlist for the public POST /owntracks receiver.
# Format: "user:pass" pairs, comma-separated. The username IS the worker identity
# stored on each ping (workerKey); a request whose creds aren't listed gets 401.
# Generate real secrets, e.g.:
#   node -e "console.log(require('crypto').randomBytes(12).toString('hex'))"
# Leave EMPTY to reject all OwnTracks posts (POC disabled).
# Example: POC_OWNTRACKS_USERS=danny:secret1,yossi:secret2
POC_OWNTRACKS_USERS=

# Seconds without a new ping before GET /owntracks/poc/debug marks a worker stale.
POC_STALE_SECONDS=180

# Public HTTPS base URL of THIS bot server (no trailing slash), used to build the
# OwnTracks magic link `/o/:token` and the `.otrc` `url` field. REQUIRED once the
# auto-provisioning flow (TASKS §4.20) is in use — createProvisioning throws
# without it. Example: PUBLIC_BASE_URL=https://bot.example.com
PUBLIC_BASE_URL=


# ─────────────────────────────────────────────────────────────────────────────
# 11. Live tracking (Wolt-lite) — OPTIONAL
# ─────────────────────────────────────────────────────────────────────────────
# ── Live tracking (Wolt-lite) ─────────────────────────────
# Set to "true" to enable road-routing (OSRM) enrichment of the public
# tracking page (route line + distance + duration-based ETA). When false/
# unset, the page falls back to a straight-line distance estimate.
TRACKING_OSRM_ENABLED=false

# OSRM routing server base URL. The default is OSRM's public demo server,
# which is documented as suitable for DEV/MVP ONLY — do not rely on it for
# production traffic. Point this at a self-hosted OSRM instance before going live.
OSRM_BASE_URL=https://router.project-osrm.org

# Public host used to build the customer-facing /t/<token> tracking link
# (e.g. https://track.example.com). Leave empty in dev. Consumed by the
# notification code that sends the link to customers.
TRACKING_PUBLIC_BASE_URL=

# Seconds without a fresh GPS ping before a worker's location is considered
# stale on the tracking page (drives the STALE_LOCATION presentation state).
TRACKING_STALE_SECONDS=120

# Distance (meters) to the destination under which the tracking page shows
# "the worker is nearby" (NEARBY presentation state) instead of "en route".
TRACKING_NEARBY_METERS=300
